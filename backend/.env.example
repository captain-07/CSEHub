SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=False

# Backend domains/hosts (comma-separated)
ALLOWED_HOSTS=csehub.onrender.com,localhost,127.0.0.1

# Preferred on Render
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local fallback when DATABASE_URL is not provided
DB_NAME=csehub_db
DB_USER=postgres
DB_PASSWORD=your-local-db-password
DB_HOST=localhost
DB_PORT=5432

# Frontend origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
SECURE_SSL_REDIRECT=True

SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_URL=https://yourproject.supabase.co

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
